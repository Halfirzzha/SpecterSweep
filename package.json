{
  "name": "spectersweep",
  "version": "2.0.0",
  "description": "SpecterSweep - Professional Instagram management tool with advanced features and modern UI",
  "author": "Halfirzzha",
  "license": "MIT",
  "keywords": [
    "instagram",
    "unfollowers",
    "social-media",
    "automation",
    "tool",
    "spectersweep"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Halfirzzha/SpecterSweep.git"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production && npm run update-readme",
    "build:dev": "webpack --mode development",
    "build:prod": "webpack --mode production",
    "serve": "webpack serve --mode development",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "echo \"Tests will be implemented\" && exit 0",
    "clean": "rimraf dist",
    "update-readme": "node scripts/update-index.js public/index.html dist/dist.js",
    "analyze": "webpack-bundle-analyzer dist/stats.json"
  },
  "babel": {
    "plugins": [
      "@babel/plugin-transform-react-jsx"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-react-jsx": "^7.25.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.7.0",
    "rimraf": "^5.0.0",
    "sass": "^1.83.4",
    "sass-loader": "^13.3.3",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "webpack": "^5.97.1",
    "webpack-bundle-analyzer": "^4.9.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "preact": "^10.25.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
